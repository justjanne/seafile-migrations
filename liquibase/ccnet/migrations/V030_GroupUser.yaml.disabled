databaseChangeLog:
- changeSet:
    id: V030_GroupUser
    author: seafile
    dbms: mysql
    changes:
    - addPrimaryKey:
        tableName: groupuser
        columnNames: group_id, user_name
    - addNotNullConstraint:
        tableName: groupuser
        columnName: group_id
        columnDataType: int
    - addNotNullConstraint:
        tableName: groupuser
        columnName: user_name
        columnDataType: varchar(255)

databaseChangeLog:
- changeSet:
    id: V030_OrgUser
    author: seafile
    dbms: mysql
    changes:
    - addPrimaryKey:
        tableName: orguser
        columnNames: org_id, email
    - addNotNullConstraint:
        tableName: orguser
        columnName: org_id
        columnDataType: int
    - addNotNullConstraint:
        tableName: orguser
        columnName: email
        columnDataType: varchar(255)

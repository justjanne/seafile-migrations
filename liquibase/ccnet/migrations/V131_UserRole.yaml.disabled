databaseChangeLog:
- changeSet:
    id: V131_UserRole
    author: seafile
    dbms: postgresql
    changes:
    - dropUniqueConstraint:
        tableName: userrole
        constraintName: userrole_email_role_key
    - dropIndex:
        tableName: userrole
        indexName: userrole_email_idx
    - addUniqueConstraint:
        tableName: userrole
        columnNames: email
    failOnError: false

databaseChangeLog:
- changeSet:
    id: V063_SystemInfo
    author: seafile
    changes:
    - addColumn:
        tableName: systeminfo
        columns:
        - column:
            name: id
            type: BIGINT
            autoIncrement: true
            constraints:
              primaryKey: true
    preConditions:
      onFail: CONTINUE
      not:
        columnExists:
          tableName: systeminfo
          columnName: id

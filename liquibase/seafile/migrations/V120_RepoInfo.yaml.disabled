databaseChangeLog:
- changeSet:
    id: V120_RepoInfo
    author: seafile
    changes:
    - addColumn:
        tableName: repoinfo
        columns:
        - column:
            name: type
            type: varchar(10)
    - createIndex:
        tableName: repoinfo
        indexName: idx_repoinfo_type
        columns:
        - column:
            name: type
    preConditions:
      onFail: CONTINUE
      not:
        columnExists:
          tableName: repoinfo
          columnName: type

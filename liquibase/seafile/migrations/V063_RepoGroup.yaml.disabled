databaseChangeLog:
- changeSet:
    id: V063_RepoGroup
    author: seafile
    changes:
    - addColumn:
        tableName: repogroup
        columns:
        - column:
            name: id
            type: BIGINT
            autoIncrement: true
            constraints:
              primaryKey: true
              primaryKeyName: RepoGroup_pkey
    preConditions:
      onFail: CONTINUE
      not:
        columnExists:
          tableName: repogroup
          columnName: id

create table `binding` ( `email` varchar(255) default null, `id` bigint(20) not null auto_increment, `peer_id` char(41) default null, primary key (`id`), unique key `peer_id` (`peer_id`), key `email` (`email`(20)) )
create table `emailuser` ( `ctime` bigint(20) default null, `email` varchar(255) default null, `id` bigint(20) not null auto_increment, `is_active` tinyint(1) not null, `is_staff` tinyint(1) not null, `passwd` varchar(256) default null, `reference_id` varchar(255) default null, primary key (`id`), unique key `email` (`email`), unique key `reference_id` (`reference_id`) )
create table `group` ( `creator_name` varchar(255) default null, `group_id` bigint(20) not null auto_increment, `group_name` varchar(255) default null, `parent_group_id` int(11) default null, `timestamp` bigint(20) default null, `type` varchar(32) default null, primary key (`group_id`) )
create table `groupdnpair` ( `dn` varchar(255) default null, `group_id` int(11) default null, `id` bigint(20) not null auto_increment, primary key (`id`) )
create table `groupstructure` ( `group_id` int(11) default null, `id` bigint(20) not null auto_increment, `path` varchar(1024) default null, primary key (`id`), unique key `group_id` (`group_id`) )
create table `groupuser` ( `group_id` bigint(20) default null, `id` bigint(20) not null auto_increment, `is_staff` tinyint(4) default null, `user_name` varchar(255) default null, primary key (`id`), unique key `group_id` (`group_id`,`user_name`), key `user_name` (`user_name`) )
create table `ldapconfig` ( `cfg_group` varchar(255) not null, `cfg_key` varchar(255) not null, `id` bigint(20) not null auto_increment, `property` int(11) default null, `value` varchar(255) default null, primary key (`id`) )
create table `ldapusers` ( `email` varchar(255) not null, `extra_attrs` text default null, `id` bigint(20) not null auto_increment, `is_active` tinyint(1) not null, `is_staff` tinyint(1) not null, `password` varchar(255) not null, `reference_id` varchar(255) default null, primary key (`id`), unique key `email` (`email`), unique key `reference_id` (`reference_id`) )
create table `organization` ( `creator` varchar(255) default null, `ctime` bigint(20) default null, `org_id` bigint(20) not null auto_increment, `org_name` varchar(255) default null, `url_prefix` varchar(255) default null, primary key (`org_id`), unique key `url_prefix` (`url_prefix`) )
create table `orggroup` ( `group_id` int(11) default null, `id` bigint(20) not null auto_increment, `org_id` int(11) default null, primary key (`id`), unique key `org_id` (`org_id`,`group_id`), key `group_id` (`group_id`) )
create table `orguser` ( `email` varchar(255) default null, `id` bigint(20) not null auto_increment, `is_staff` tinyint(1) not null, `org_id` int(11) default null, primary key (`id`), unique key `org_id` (`org_id`,`email`), key `email` (`email`) )
create table `userrole` ( `email` varchar(255) default null, `id` bigint(20) not null auto_increment, `role` varchar(255) default null, primary key (`id`), unique key `email` (`email`) )
